# Superbrain — local development environment
# Copy to .env and fill in. Never commit .env.

BRAIN_ENV=local
BRAIN_DEBUG=true
BRAIN_LOG_LEVEL=INFO
BRAIN_BUSINESS_DIR=your-business

# Postgres / Supabase
POSTGRES_DSN=postgresql://brain:brain@localhost:5432/brain
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# Cognee
COGNEE_URL=http://localhost:8001
COGNEE_API_KEY=
COGNEE_DEFAULT_DATASET=company_brain

# Graphiti (Neo4j-compatible)
GRAPHITI_URL=bolt://localhost:7687
GRAPHITI_USER=neo4j
GRAPHITI_PASSWORD=

# Mem0
MEM0_URL=http://localhost:8002
MEM0_API_KEY=

# Object store (filesystem | s3 | azure_blob)
OBJECT_STORE_BACKEND=filesystem
OBJECT_STORE_PATH=./var/blobs

# Microsoft Graph (Entra app registration)
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=

# Plexa
PLEXA_BASE_URL=
PLEXA_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
